@@ -1328,2 +1328,44 @@ async fn status_line_legacy_context_usage_renders_context_used_percent() {
 
+#[tokio::test]
+async fn status_line_codex_hud_renders_bars_and_reset() {
+    let (mut chat, _rx, _op_rx) = make_chatwidget_manual(/*model_override*/ None).await;
+    chat.thread_id = Some(ThreadId::new());
+    chat.config.tui_status_line = Some(vec!["codex-hud".to_string()]);
+
+    chat.handle_codex_event(Event {
+        id: "token-usage".into(),
+        msg: EventMsg::TokenCount(TokenCountEvent {
+            info: Some(make_token_info(
+                /*total_tokens*/ 12_042, /*context_window*/ 12_100,
+            )),
+            rate_limits: None,
+        }),
+    });
+    chat.on_rate_limit_snapshot(Some(RateLimitSnapshot {
+        limit_id: None,
+        limit_name: None,
+        primary: Some(RateLimitWindow {
+            used_percent: 25.0,
+            window_minutes: Some(300),
+            resets_at: Some(chrono::Utc::now().timestamp() + 2 * 60 * 60),
+        }),
+        secondary: Some(RateLimitWindow {
+            used_percent: 60.0,
+            window_minutes: Some(10_080),
+            resets_at: Some(chrono::Utc::now().timestamp() + 3 * 24 * 60 * 60 + 4 * 60 * 60),
+        }),
+        credits: None,
+        plan_type: None,
+        rate_limit_reached_type: None,
+    }));
+
+    assert_eq!(
+        status_line_text(&chat),
+        Some(
+            "Context \u{2588}\u{2588}\u{2588}\u{2591}\u{2591} 42% \u{2502} Usage \u{2588}\u{2588}\u{2588}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591} 25% (2h / 5h) \u{2502} Weekly \u{2588}\u{2588}\u{2588}\u{2588}\u{2588}\u{2588}\u{2591}\u{2591}\u{2591}\u{2591} 60% (3d 4h / 7d)"
+                .to_string()
+        )
+    );
+}
+
 #[tokio::test]
