diff --git a/codex-rs/tui/src/chatwidget/hud_status.rs b/codex-rs/tui/src/chatwidget/hud_status.rs
new file mode 100644
index 0000000..9597494
--- /dev/null
+++ b/codex-rs/tui/src/chatwidget/hud_status.rs
@@ -0,0 +1,185 @@
+use std::collections::BTreeMap;
+use std::path::Path;
+
+use crate::status::RateLimitSnapshotDisplay;
+use crate::status::RateLimitWindowDisplay;
+
+const HUD_SEPARATOR: &str = " \u{2502} ";
+
+pub(crate) fn codex_hud_status_line(
+    _codex_home: &Path,
+    context_used_percent: i64,
+    rate_limit_snapshots_by_limit_id: &BTreeMap<String, RateLimitSnapshotDisplay>,
+) -> String {
+    let context_used_percent = context_used_percent.clamp(0, 100);
+    let mut parts = vec![format!(
+        "Context {} {context_used_percent}%",
+        context_hud_bar(context_used_percent as f64)
+    )];
+
+    let live_limits = rate_limit_snapshots_by_limit_id.get("codex");
+
+    parts.push(hud_usage_segment(
+        "Usage",
+        live_limits.and_then(|snapshot| snapshot.primary.as_ref()),
+        /*default_window_minutes*/ 300,
+    ));
+    parts.push(hud_usage_segment(
+        "Weekly",
+        live_limits.and_then(|snapshot| snapshot.secondary.as_ref()),
+        /*default_window_minutes*/ 10_080,
+    ));
+
+    parts.join(HUD_SEPARATOR)
+}
+
+fn hud_usage_segment(
+    label: &str,
+    window: Option<&RateLimitWindowDisplay>,
+    default_window_minutes: i64,
+) -> String {
+    let total_window = window
+        .and_then(|window| window.window_minutes)
+        .unwrap_or(default_window_minutes);
+    let total_window = hud_window_duration(total_window);
+
+    let Some(window) = window else {
+        return format!(
+            "{label} {} --% (-- / {total_window})",
+            usage_hud_bar(/*percent_used*/ 0.0)
+        );
+    };
+
+    let used = window.used_percent.clamp(0.0, 100.0);
+    let reset = window
+        .reset_after_seconds
+        .map(hud_remaining_duration)
+        .unwrap_or_else(|| "--".to_string());
+    format!(
+        "{label} {} {used:.0}% ({reset} / {total_window})",
+        usage_hud_bar(used)
+    )
+}
+
+fn context_hud_bar(percent_used: f64) -> String {
+    hud_bar(percent_used, /*segments*/ 5)
+}
+
+fn usage_hud_bar(percent_used: f64) -> String {
+    hud_bar(percent_used, /*segments*/ 10)
+}
+
+fn hud_bar(percent_used: f64, segments: usize) -> String {
+    const FILLED: &str = "\u{2588}";
+    const EMPTY: &str = "\u{2591}";
+
+    let percent_used = percent_used.clamp(0.0, 100.0);
+    let filled = if percent_used <= 0.0 {
+        0
+    } else {
+        ((percent_used / 100.0) * segments as f64).ceil() as usize
+    }
+    .min(segments);
+    let empty = segments.saturating_sub(filled);
+    format!("{}{}", FILLED.repeat(filled), EMPTY.repeat(empty))
+}
+
+fn hud_window_duration(window_minutes: i64) -> String {
+    const MINUTES_PER_HOUR: i64 = 60;
+    const MINUTES_PER_DAY: i64 = 24 * MINUTES_PER_HOUR;
+
+    let window_minutes = window_minutes.max(0);
+    if window_minutes >= MINUTES_PER_DAY && window_minutes % MINUTES_PER_DAY == 0 {
+        format!("{}d", window_minutes / MINUTES_PER_DAY)
+    } else if window_minutes >= MINUTES_PER_HOUR && window_minutes % MINUTES_PER_HOUR == 0 {
+        format!("{}h", window_minutes / MINUTES_PER_HOUR)
+    } else {
+        format!("{window_minutes}m")
+    }
+}
+
+fn hud_remaining_duration(seconds: i64) -> String {
+    const MINUTES_PER_HOUR: i64 = 60;
+    const MINUTES_PER_DAY: i64 = 24 * MINUTES_PER_HOUR;
+
+    let total_minutes = if seconds <= 0 { 0 } else { (seconds + 59) / 60 };
+    let days = total_minutes / MINUTES_PER_DAY;
+    let hours = (total_minutes % MINUTES_PER_DAY) / MINUTES_PER_HOUR;
+    let minutes = total_minutes % MINUTES_PER_HOUR;
+
+    if days > 0 {
+        if hours > 0 {
+            format!("{days}d {hours}h")
+        } else {
+            format!("{days}d")
+        }
+    } else if hours > 0 {
+        if minutes > 0 {
+            format!("{hours}h {minutes}m")
+        } else {
+            format!("{hours}h")
+        }
+    } else {
+        format!("{minutes}m")
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use pretty_assertions::assert_eq;
+    use serde_json::json;
+    use std::fs;
+    use tempfile::tempdir;
+
+    #[test]
+    fn hud_does_not_use_session_rate_limits_as_fresh_usage() {
+        let codex_home = tempdir().expect("create temp codex home");
+        let session_dir = codex_home.path().join("sessions/2026/04/24");
+        fs::create_dir_all(&session_dir).expect("create session dir");
+        let resets_at = chrono::Utc::now().timestamp() + 2 * 60 * 60;
+        let session_line = json!({
+            "timestamp": "2026-04-24T06:11:48.187Z",
+            "type": "event_msg",
+            "payload": {
+                "type": "token_count",
+                "info": null,
+                "rate_limits": {
+                    "limit_id": "codex",
+                    "limit_name": null,
+                    "primary": {
+                        "used_percent": 39.0,
+                        "window_minutes": 300,
+                        "resets_at": resets_at,
+                    },
+                    "secondary": {
+                        "used_percent": 43.0,
+                        "window_minutes": 10080,
+                        "resets_at": null,
+                    },
+                    "credits": null,
+                    "plan_type": "prolite",
+                    "rate_limit_reached_type": null,
+                },
+            },
+        });
+        fs::write(
+            session_dir.join("rollout-test.jsonl"),
+            format!("{}\n", session_line),
+        )
+        .expect("write session");
+
+        assert_eq!(
+            codex_hud_status_line(codex_home.path(), 81, &BTreeMap::new()),
+            "Context \u{2588}\u{2588}\u{2588}\u{2588}\u{2588} 81% \u{2502} Usage \u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591} --% (-- / 5h) \u{2502} Weekly \u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591} --% (-- / 7d)"
+        );
+    }
+
+    #[test]
+    fn hud_always_reserves_both_usage_windows_when_missing() {
+        assert_eq!(
+            codex_hud_status_line(Path::new("missing"), 42, &BTreeMap::new()),
+            "Context \u{2588}\u{2588}\u{2588}\u{2591}\u{2591} 42% \u{2502} Usage \u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591} --% (-- / 5h) \u{2502} Weekly \u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591}\u{2591} --% (-- / 7d)"
+        );
+    }
+}
